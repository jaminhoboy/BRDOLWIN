# Variáveis de Ambiente do Atlas Bot
# Copie este arquivo para .env e preencha os valores reais

# Supabase (mesmo projeto que o frontend usa)
SUPABASE_URL=https://SEU_PROJETO.supabase.co
SUPABASE_SERVICE_KEY=sua_service_role_key_aqui

# Porta do servidor Express (Render usa PORT automático)
PORT=3000

# Intervalo do loop de análise em milissegundos (padrão: 8000 = 8 segundos)
TICK_INTERVAL_MS=8000

# Intervalo de sincronização de configurações (padrão: 30000 = 30 segundos)
SETTINGS_SYNC_INTERVAL_MS=30000
